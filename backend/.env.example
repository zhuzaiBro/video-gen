# 后端专用配置（复制为 backend/.env）
# 也可继续使用项目根目录 .env，backend/.env 优先级更高

# Supabase PostgreSQL
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# Supabase Auth（ES256 通过 JWKS 验证；也可填 VITE_SUPABASE_URL）
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
# 仅旧版 HS256 JWT 项目需要
SUPABASE_JWT_SECRET=

# Kling AI
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api-beijing.klingai.com
KLING_MODEL_NAME=kling-v3
KLING_DEFAULT_MODE=std

# 通义千问（视频脚本拆解 / 首帧质检）
DASHSCOPE_API_KEY=
# 文本/视觉模型走 compatible-mode；万相文生图走原生 API（自动推导，一般无需改）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 国际区示例：DASHSCOPE_NATIVE_BASE_URL=https://dashscope-intl.aliyuncs.com
QWEN_VL_MODEL=qwen-vl-max
QWEN_TEXT_MODEL=qwen-plus
WANX_MODEL=wan2.2-t2i-flash
QWEN_AUDIO_MODEL=qwen-audio-turbo

# 腾讯云 COS
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-shanghai
